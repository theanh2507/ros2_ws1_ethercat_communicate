<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="hexapod_single_leg">

  <!-- <xacro:include filename="$(find hexapod_controller)/description/ros2_control/motor.ros2_control.xacro" /> -->

  <link name="map"/>

  <joint name="virtual_joint" type="fixed">
    <parent link="map"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.2"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/> </material>
    </visual>
  </link>


  <!-- truc dong co-->
  <link name="leg_1">
    <visual>
      <geometry>
        <cylinder length="0.3" radius="0.02"/>
      </geometry>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="joint_1" type="continuous">
    <parent link="base_link"/>
    <child link="leg_1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/> -->
  </joint>

  <!-- <xacro:ethercat_control_setup /> -->

</robot>